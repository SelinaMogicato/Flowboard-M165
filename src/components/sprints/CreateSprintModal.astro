---
import Modal from "../ui/Modal.astro";
import Input from "../ui/Input.astro";
import Button from "../ui/Button.astro";

interface Props {
  projectId: string;
  unassignedIssues?: any[];
}

const { projectId, unassignedIssues = [] } = Astro.props;
const id = "create_sprint_modal";
---

<Modal id={id} title="Start a New Sprint">
  <form id="create_sprint_form" class="space-y-4">
    <Input name="name" label="Sprint Name" placeholder="Sprint 1" required />

    <div>
      <label
        class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
        >Sprint Goal</label
      >
      <textarea
        name="goal"
        rows="2"
        placeholder="What do we want to achieve?"
        class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
      ></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label
          class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
          >Start Date</label
        >
        <input
          type="date"
          name="startDate"
          class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
        />
      </div>
      <div>
        <label
          class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
          >End Date</label
        >
        <input
          type="date"
          name="endDate"
          class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
        />
      </div>
    </div>

    {
      unassignedIssues.length > 0 && (
        <div>
          <label class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-2">
            Unassigned Issues
          </label>
          <div class="bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 rounded-xl overflow-hidden max-h-48 overflow-y-auto">
            {unassignedIssues.map((issue) => (
              <label class="flex items-center gap-3 px-3 py-2 hover:bg-surface-100 dark:hover:bg-ink-800 cursor-pointer border-b border-ink-100 dark:border-ink-800 last:border-0">
                <input
                  type="checkbox"
                  name="issueIds"
                  value={issue._id}
                  class="rounded text-peach-500 focus:ring-peach-500"
                />
                <span class="text-sm text-ink-700 dark:text-ink-200 truncate">
                  {issue.title}
                </span>
              </label>
            ))}
          </div>
          <p class="text-xs text-ink-400 mt-1">
            Select issues to add to this sprint.
          </p>
        </div>
      )
    }

    <div
      class="flex justify-end gap-2 pt-4 border-t border-ink-100 dark:border-ink-700 mt-4"
    >
      <Button
        variant="secondary"
        type="button"
        onclick="document.getElementById('create_sprint_modal').close()"
        >Cancel</Button
      >
      <Button type="submit">Create Sprint</Button>
    </div>
  </form>
</Modal>

<script define:vars={{ projectId }}>
  const form = document.getElementById("create_sprint_form");
  // @ts-ignore
  const modal = document.getElementById("create_sprint_modal");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);

    // Handle multiple checkboxes for issueIds
    const issueIds = [];
    // @ts-ignore
    document
      .querySelectorAll('input[name="issueIds"]:checked')
      .forEach((checkbox) => {
        // @ts-ignore
        issueIds.push(checkbox.value);
      });
    data.issueIds = issueIds;

    // Simple validation if needed

    try {
      const res = await fetch(`/api/projects/${projectId}/sprints`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert("Failed to create sprint");
      }
    } catch (err) {
      console.error(err);
      alert("Error creating sprint");
    }
  });
</script>
