---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";

interface Props {
  // No props needed as it's populated via JS
}

const id = "edit_sprint_modal";
---

<Modal id={id} title="Edit Sprint">
  <form id="edit_sprint_form" class="space-y-4">
    <input type="hidden" name="sprintId" id="edit_sprint_id" />

    <div>
      <label
        class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
        >Sprint Name</label
      >
      <input
        type="text"
        name="name"
        id="edit_sprint_name"
        required
        class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
      />
    </div>

    <div>
      <label
        class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
        >Sprint Goal</label
      >
      <textarea
        name="goal"
        id="edit_sprint_goal"
        rows="2"
        placeholder="What's the goal?"
        class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
      ></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label
          class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
          >Start Date</label
        >
        <input
          type="date"
          name="startDate"
          id="edit_sprint_start_date"
          class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
        />
      </div>
      <div>
        <label
          class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1"
          >End Date</label
        >
        <input
          type="date"
          name="endDate"
          id="edit_sprint_end_date"
          class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"
        />
      </div>
    </div>

    <div
      class="flex justify-end gap-2 pt-4 border-t border-ink-100 dark:border-ink-700 mt-4"
    >
      <Button
        variant="secondary"
        type="button"
        onclick="document.getElementById('edit_sprint_modal').close()"
        >Cancel</Button
      >
      <Button type="submit">Save Changes</Button>
    </div>
  </form>
</Modal>

<script>
  window.editSprint = async (sprintId: string) => {
    try {
      const res = await fetch(`/api/sprints/${sprintId}`);
      const sprint = await res.json();

      if (sprint && !sprint.error) {
        const modal = document.getElementById(
          "edit_sprint_modal",
        ) as HTMLDialogElement;

        (document.getElementById("edit_sprint_id") as HTMLInputElement).value =
          sprint._id;
        (
          document.getElementById("edit_sprint_name") as HTMLInputElement
        ).value = sprint.name || "";
        (
          document.getElementById("edit_sprint_goal") as HTMLInputElement
        ).value = sprint.goal || "";

        if (sprint.startDate) {
          (
            document.getElementById(
              "edit_sprint_start_date",
            ) as HTMLInputElement
          ).value = new Date(sprint.startDate).toISOString().split("T")[0];
        } else {
          (
            document.getElementById(
              "edit_sprint_start_date",
            ) as HTMLInputElement
          ).value = "";
        }

        if (sprint.endDate) {
          (
            document.getElementById("edit_sprint_end_date") as HTMLInputElement
          ).value = new Date(sprint.endDate).toISOString().split("T")[0];
        } else {
          (
            document.getElementById("edit_sprint_end_date") as HTMLInputElement
          ).value = "";
        }

        modal?.showModal();
      } else {
        alert("Failed to load sprint details");
      }
    } catch (e) {
      console.error(e);
      alert("Error loading sprint");
    }
  };

  const form = document.getElementById("edit_sprint_form");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const data = Object.fromEntries(formData);
    const sprintId = data.sprintId;

    // Remove sprintId from body if API doesn't want it (though it's harmless usually)
    delete data.sprintId;

    try {
      const res = await fetch(`/api/sprints/${sprintId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert(err.error || "Failed to update sprint");
      }
    } catch (e) {
      console.error(e);
      alert("Error updating sprint");
    }
  });
</script>
