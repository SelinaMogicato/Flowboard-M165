---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";

interface Props {
  id?: string;
}

const { id = "delete_sprint_modal" } = Astro.props;
---

<Modal id={id} title="Delete Sprint?">
  <div class="space-y-4">
    <p class="text-ink-600 dark:text-ink-300">
      Are you sure you want to delete this sprint? All issues will be moved back
      to the backlog.
    </p>

    <input type="hidden" id="delete_sprint_id" />

    <div class="flex justify-end gap-3 pt-2">
      <Button
        variant="secondary"
        onclick={`document.getElementById('${id}').close()`}>Cancel</Button
      >
      <Button
        variant="primary"
        class="!bg-red-600 hover:!bg-red-700 dark:!bg-red-500/80 dark:hover:!bg-red-500 !text-white border-none"
        id="confirm_delete_sprint">Delete</Button
      >
    </div>
  </div>
</Modal>

<script>
  // @ts-nocheck
  const modal = document.getElementById("delete_sprint_modal");
  const confirmBtn = document.getElementById("confirm_delete_sprint");
  const inputId = document.getElementById("delete_sprint_id");

  window.openDeleteSprintDialog = (sprintId) => {
    if (inputId) inputId.value = sprintId;
    if (modal) modal.showModal();
  };

  confirmBtn?.addEventListener("click", async () => {
    const sprintId = inputId?.value;
    if (!sprintId) return;

    const originalText = confirmBtn.textContent;
    confirmBtn.textContent = "Deleting...";
    confirmBtn.disabled = true;

    try {
      const res = await fetch(`/api/sprints/${sprintId}`, {
        method: "DELETE",
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        alert(data.error || "Failed to delete sprint");
      }
    } catch (err) {
      console.error(err);
      alert("Error deleting sprint");
    } finally {
      confirmBtn.textContent = originalText;
      confirmBtn.disabled = false;
      modal.close();
    }
  });
</script>
