---
// Topbar.astro (FlowBoard)
// - Token based (surface/ink/peach)
// - Click menus (touch friendly)
// - Outside click + ESC closes
// - aria-expanded correct

import { ProjectService } from "../../lib/services/project.service";
import type { User } from "../../lib/repositories/user.repo";

interface Props {
  user?: User;
}

const { user } = Astro.props;

let projects: any[] = [];
// Use optional chaining and ensure _id exists and convert to string
if (user?._id) {
  try {
    projects = await ProjectService.getAllProjects(false, user._id.toString());
  } catch (e) {}
}

const url = new URL(Astro.request.url);
const pathSegments = url.pathname.split("/");
const currentProjectId = pathSegments[2];
const currentProject =
  projects.find((p) => p._id.toString() === currentProjectId) || projects[0];

const initials = (user?.name?.[0] || user?.email?.[0] || "U").toUpperCase();
---

<header
  id="topbar"
  class="sticky top-0 z-30 h-20
         bg-surface-50/85 dark:bg-ink-900/75 backdrop-blur
         border-b border-ink-100/70 dark:border-ink-700/50
         transition-shadow duration-200"
>
  <div class="h-full px-4 sm:px-6 flex items-center justify-between gap-4">
    <!-- Left cluster -->
    <div class="flex items-center gap-3">
      <!-- Sidebar open -->
      <button
        type="button"
        class="md:hidden p-2 rounded-xl transition-colors
               text-ink-600 hover:bg-ink-100
               dark:text-ink-300 dark:hover:bg-ink-800
               focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70 focus-visible:ring-offset-2
               focus-visible:ring-offset-surface-50 dark:focus-visible:ring-offset-ink-900"
        aria-label="Open sidebar"
        onclick="
          document.getElementById('sidebar')?.classList.remove('-translate-x-full');
          document.getElementById('sidebar-backdrop')?.classList.remove('hidden');
        "
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-6 h-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>

      <!-- Project switcher -->
      <div class="relative">
        <button
          id="project-switcher"
          type="button"
          class="hidden sm:flex items-center gap-2 px-3 py-2 rounded-2xl
                 bg-surface-200/70 dark:bg-ink-800/60
                 border border-ink-100/70 dark:border-ink-700/50
                 text-sm font-medium text-ink-800 dark:text-ink-100
                 hover:bg-surface-300/70 dark:hover:bg-ink-800
                 transition-colors
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70 focus-visible:ring-offset-2
                 focus-visible:ring-offset-surface-50 dark:focus-visible:ring-offset-ink-900"
          aria-haspopup="menu"
          aria-expanded="false"
          onclick="
            const pm = document.getElementById('project-menu');
            const pmOpen = pm?.classList.toggle('hidden') === false;
            this.setAttribute('aria-expanded', String(pmOpen));
          "
        >
          <span class="w-2 h-2 rounded-full bg-peach-500"></span>
          <span class="max-w-[14rem] truncate">
            {currentProject ? currentProject.name : "Select Project"}
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4 text-ink-500 dark:text-ink-300"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>

        <div
          id="project-menu"
          class="absolute left-0 top-full mt-2 w-64 hidden z-50
                 rounded-2xl shadow-card
                 bg-surface-50 dark:bg-ink-800
                 border border-ink-100 dark:border-ink-700
                 overflow-hidden"
          role="menu"
        >
          <div
            class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-300 border-b border-ink-100/70 dark:border-ink-700/70"
          >
            Your Projects
          </div>

          <div class="max-h-64 overflow-auto py-1">
            {
              projects.length > 0 ? (
                projects.map((p) => {
                  const active =
                    currentProject &&
                    p._id.toString() === currentProject._id.toString();
                  return (
                    <a
                      href={`/projects/${p._id}`}
                      role="menuitem"
                      class:list={[
                        "flex items-center justify-between gap-2 px-3 py-2 text-sm transition-colors truncate",
                        "text-ink-800 dark:text-ink-100 hover:bg-peach-50 dark:hover:bg-ink-700/70",
                        active && "bg-peach-50/70 dark:bg-ink-700/50",
                      ]}
                    >
                      <span class="truncate">{p.name}</span>
                      {active && (
                        <span
                          class="h-2 w-2 rounded-full bg-peach-500 flex-none"
                          aria-hidden="true"
                        />
                      )}
                    </a>
                  );
                })
              ) : (
                <div class="px-3 py-2 text-sm text-ink-500 dark:text-ink-300 italic">
                  No projects found
                </div>
              )
            }
          </div>

          <div class="border-t border-ink-100/70 dark:border-ink-700/70">
            <a
              href="/projects?action=create"
              role="menuitem"
              class="block px-3 py-2 text-sm font-medium
                     text-peach-700 dark:text-peach-300
                     hover:bg-peach-50 dark:hover:bg-ink-700/70 transition-colors"
            >
              + Create New Project
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right cluster -->
    <div class="flex items-center gap-2">
      <div class="relative">
        <button
          id="user-menu-button"
          type="button"
          class="flex items-center gap-3 pl-2 pr-2 py-1.5 rounded-full
                 hover:bg-ink-50 dark:hover:bg-ink-800/70 transition-colors
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70 focus-visible:ring-offset-2
                 focus-visible:ring-offset-surface-50 dark:focus-visible:ring-offset-ink-900"
          aria-haspopup="menu"
          aria-expanded="false"
          onclick="
            const um = document.getElementById('user-menu');
            const umOpen = um?.classList.toggle('hidden') === false;
            this.setAttribute('aria-expanded', String(umOpen));
          "
        >
          <span
            class="hidden sm:block text-sm font-medium text-ink-800 dark:text-ink-100 max-w-[12rem] truncate"
          >
            {user?.name || user?.email || "User"}
          </span>

          <div
            class="w-9 h-9 rounded-full bg-peach-500 text-white flex items-center justify-center font-semibold shadow-sm"
          >
            {initials}
          </div>
        </button>

        <div
          id="user-menu"
          class="absolute right-0 top-full mt-2 w-56 hidden z-50
                 rounded-2xl shadow-card
                 bg-surface-50 dark:bg-ink-800
                 border border-ink-100 dark:border-ink-700
                 overflow-hidden"
          role="menu"
        >
          <div
            class="px-4 py-3 border-b border-ink-100/70 dark:border-ink-700/70"
          >
            <p
              class="text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-300"
            >
              Signed in as
            </p>
            <p
              class="text-sm font-semibold text-ink-900 dark:text-ink-100 truncate"
            >
              {user?.email}
            </p>
          </div>

          <div class="p-1">
            <button
              id="logout-btn"
              type="button"
              class="w-full text-left px-3 py-2 rounded-xl text-sm
                     text-red-700 dark:text-red-300
                     hover:bg-red-50 dark:hover:bg-ink-700/70
                     transition-colors
                     focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70"
            >
              Sign out
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Behavior -->
  <script is:inline>
    // Logout via API
    document
      .getElementById("logout-btn")
      ?.addEventListener("click", async () => {
        try {
          const res = await fetch("/api/auth/logout", { method: "POST" });
          if (res.ok) window.location.href = "/login";
        } catch (e) {
          console.error(e);
        }
      });

    const projectMenu = document.getElementById("project-menu");
    const projectBtn = document.getElementById("project-switcher");
    const userMenu = document.getElementById("user-menu");
    const userBtn = document.getElementById("user-menu-button");

    const closeAll = () => {
      projectMenu?.classList.add("hidden");
      userMenu?.classList.add("hidden");
      projectBtn?.setAttribute("aria-expanded", "false");
      userBtn?.setAttribute("aria-expanded", "false");
    };

    document.addEventListener("click", (e) => {
      const t = e.target;
      const insideProject = projectBtn?.contains(t) || projectMenu?.contains(t);
      const insideUser = userBtn?.contains(t) || userMenu?.contains(t);
      if (!insideProject && !insideUser) closeAll();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });

    // Subtle shadow on scroll
    const topbar = document.getElementById("topbar");
    const onScroll = () => {
      if (!topbar) return;
      if (window.scrollY > 2) topbar.classList.add("shadow-sm");
      else topbar.classList.remove("shadow-sm");
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  </script>
</header>
