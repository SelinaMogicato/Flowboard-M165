---
const currentPath = new URL(Astro.request.url).pathname;
const projectMatch = currentPath.match(/^\/projects\/([^\/]+)/);
const projectId = projectMatch ? projectMatch[1] : null;

const links = [
  { href: "/projects", label: "Projects", icon: "grid" },
  // If we are in a project, show Board and Issues for that project
  ...(projectId
    ? [
        { href: `/projects/${projectId}`, label: "Board", icon: "kanban" },
        {
          href: `/projects/${projectId}/issues`,
          label: "Issues",
          icon: "list",
        },
        {
          href: `/projects/${projectId}/sprints`,
          label: "Sprints",
          icon: "activity",
        },
        {
          href: `/projects/${projectId}/settings/members`,
          label: "Members",
          icon: "users",
        },
      ]
    : [
        // Fallback or global links if not in a project
        { href: "/board", label: "Board", icon: "kanban" },
      ]),
  { href: "/settings/profile", label: "Settings", icon: "settings" },
];

// Helper to determine if a link is active
const isActive = (href: string) => {
  if (href === "/projects") {
    // Projects active if path is exactly /projects or /projects/
    return currentPath === "/projects" || currentPath === "/projects/";
  }
  // For dynamic project links, exact match or sub-paths (unless it's another main link)
  if (projectId && href.startsWith(`/projects/${projectId}`)) {
    if (href === `/projects/${projectId}`) {
      // Board view: active on exact match or if no other sub-route matched (default)
      // But strict equality is better if we have explicit links for others
      return currentPath === href || currentPath === href + "/";
    }
    return currentPath.startsWith(href);
  }

  if (href === "/board") {
    return currentPath === "/board";
  }

  return currentPath.startsWith(href);
};
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-50 w-64 -translate-x-full md:translate-x-0 transform transition-transform duration-300
         bg-peach-fog text-white shadow-card"
>
  <!-- Header -->
  <div class="h-20 flex items-center px-8 border-b border-white/10">
    <img
      src="/icon.png"
      alt="FlowBoard Logo"
      class="w-8 h-8 rounded-full mr-3 object-cover ring-1 ring-white/15"
    />
    <div class="min-w-0">
      <h1 class="text-lg font-bold tracking-tight leading-tight">FlowBoard</h1>
      <p class="text-xs text-white/60 leading-tight mt-0.5">Sprint & Backlog</p>
    </div>
  </div>

  <!-- Nav -->
  <nav class="px-3 py-4 space-y-1 mt-2">
    {
      links.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
          class:list={[
            "flex items-center gap-3 px-4 py-3 rounded-2xl transition-all duration-200 group",
            isActive(link.href)
              ? "bg-white/20 font-semibold shadow-inner text-white"
              : "text-white/80 hover:bg-white/10 hover:text-white",
          ]}
        >
          <span
            class:list={[
              "w-5 h-5 flex-none opacity-80 transition-opacity duration-200",
              isActive(link.href) ? "opacity-95" : "group-hover:opacity-95",
            ]}
            aria-hidden="true"
          >
            {link.icon === "users" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"
                />
              </svg>
            )}
            {link.icon === "grid" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25A2.25 2.25 0 0110.5 15.75V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 01-2.25 2.25H15.75A2.25 2.25 0 0113.5 8.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"
                />
              </svg>
            )}

            {link.icon === "kanban" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125z"
                />
              </svg>
            )}
            {link.icon === "list" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 17.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                />
              </svg>
            )}
            {link.icon === "activity" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3.75 13.5l6-6 4.5 4.5 6-7.5"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 6v6h-6"
                />
              </svg>
            )}

            {link.icon === "settings" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M10.5 6.75h3m-1.5 0v10.5m-7.5-6h3m9 0h3M6.343 6.343l2.121 2.121m7.072 7.072 2.121 2.121M17.657 6.343l-2.121 2.121M8.464 15.536l-2.121 2.121"
                />
              </svg>
            )}
          </span>

          <span class="text-sm font-medium leading-none">{link.label}</span>

          {isActive(link.href) && (
            <span
              class="ml-auto h-2 w-2 rounded-full bg-white/70"
              aria-hidden="true"
            />
          )}
        </a>
      ))
    }
  </nav>
</aside>

<div
  id="sidebar-backdrop"
  class="fixed inset-0 z-40 bg-ink-900/50 md:hidden hidden"
  onclick="document.getElementById('sidebar')?.classList.add('-translate-x-full'); this.classList.add('hidden')"
>
</div>
