---
import AppLayout from "../../../../layouts/AppLayout.astro";
import { SprintService } from "../../../../lib/services/sprint.service";
import { ProjectService } from "../../../../lib/services/project.service";
import { IssueService } from "../../../../lib/services/issue.service";
import CreateSprintModal from "../../../../components/sprints/CreateSprintModal.astro";
import EditSprintModal from "../../../../components/sprints/EditSprintModal.astro";
import DeleteSprintDialog from "../../../../components/sprints/DeleteSprintDialog.astro";
import StartSprintDialog from "../../../../components/sprints/StartSprintDialog.astro";
import CompleteSprintDialog from "../../../../components/sprints/CompleteSprintDialog.astro";
import Button from "../../../../components/ui/Button.astro";

const { projectId } = Astro.params;

let sprints: any[] = [];
let unassignedIssues: any[] = [];
let project: any;

if (projectId && Astro.locals.user) {
  try {
    project = await ProjectService.getProjectById(projectId, Astro.locals.user._id?.toString());
    if (!project) return Astro.redirect('/projects');
    sprints = await SprintService.getAllSprints(projectId);
    unassignedIssues = await IssueService.getUnassignedIssues(projectId);
  } catch (e) {
    console.error(e);
    return Astro.redirect("/404");
  }
}

const getStatusColor = (status: string) => {
  switch (status) {
    case "active":
      return "text-green-600 bg-green-50 dark:bg-green-900/20 dark:text-green-300";
    case "completed":
      return "text-ink-600 bg-surface-200/70 dark:bg-ink-800 dark:text-ink-300";
    default:
      return "text-blue-600 bg-blue-50 dark:bg-blue-900/20 dark:text-blue-300";
  }
};

const activeSprint = sprints.find((s) => s.status === "active");
---

<AppLayout title={`Sprints - ${project?.name}`}>
  <div class="h-full min-h-0 flex flex-col">
    <!-- Project Navigation Header -->
    <div class="mb-8 border-b border-ink-200 dark:border-ink-700 pb-1">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-3xl font-bold text-ink-900 dark:text-ink-50 flex items-center gap-4">
          <div>
             {project?.name}
             <span class="text-ink-400 font-normal text-lg">/ Sprints</span>
          </div>
          {activeSprint && (
            <a href={`/projects/${projectId}/sprints/${activeSprint._id}`} class="text-sm font-medium px-3 py-1 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300 rounded-full flex items-center gap-2 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              Active: {activeSprint.name}
            </a>
          )}
        </h1>

        <div class="flex items-center gap-2 mt-1">
          <a
            href={`/projects/${projectId}`}
            class="px-3 py-1 text-ink-500 dark:text-ink-400 hover:bg-surface-100 dark:hover:bg-ink-800 rounded-lg text-sm transition-colors"
          >
            Board
          </a>
          <a
            href={`/projects/${projectId}/issues`}
            class="px-3 py-1 text-ink-500 dark:text-ink-400 hover:bg-surface-100 dark:hover:bg-ink-800 rounded-lg text-sm transition-colors"
          >
            List
          </a>
          <div class="px-3 py-1 bg-peach-500 text-white rounded-lg text-sm font-medium">
            Sprints
          </div>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
      <div class="flex gap-4 text-sm font-medium">
        <span class="flex items-center gap-2 text-ink-900 dark:text-ink-50 underline decoration-2 decoration-peach-500 underline-offset-8">
          All
          <span class="bg-ink-100 dark:bg-ink-800 px-2 py-0.5 rounded-full text-xs">
            {sprints.length}
          </span>
        </span>
      </div>

      <div class="flex gap-3 w-full sm:w-auto items-center flex-wrap justify-end">
        <Button onclick="document.getElementById('create_sprint_modal').showModal()">
          Create Sprint
        </Button>
      </div>
    </div>

    <!-- Sprint List -->
    <div class="bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 rounded-2xl overflow-hidden shadow-sm">
      {sprints.length > 0 ? (
        <ul class="divide-y divide-ink-100 dark:divide-ink-800">
          {sprints.map((sprint) => (
            <li 
              class="hover:bg-surface-100 dark:hover:bg-ink-800/50 transition-colors group flex flex-col cursor-pointer"
              onclick={`window.location.href = '/projects/${projectId}/sprints/${sprint._id}'`}
            >
              <div class="p-4 flex items-start gap-4">
                <div class="pt-1">
                  {sprint.status === "active" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                  ) : sprint.status === "completed" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-ink-400" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm5-8a1 1 0 10-2 0v.01A1 1 0 0015 10zm-4 0a1 1 0 10-2 0v.01A1 1 0 0011 10zm-4 0a1 1 0 10-2 0v.01A1 1 0 007 10z" clip-rule="evenodd" />
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
                    </svg>
                  )}
                </div>

                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <a
                      href={`/projects/${projectId}/sprints/${sprint._id}`}
                      class="text-base font-semibold text-ink-900 dark:text-ink-100 truncate block text-left hover:underline"
                    >
                      {sprint.name}
                    </a>

                    <span class={`px-2 py-0.5 rounded-md text-xs font-medium ${getStatusColor(sprint.status)}`}>
                      {sprint.status}
                    </span>
                  </div>

                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-ink-500 dark:text-ink-400">
                    {sprint.goal && (
                      <>
                        <span class="max-w-[320px] truncate">{sprint.goal}</span>
                        <span>&middot;</span>
                      </>
                    )}

                    {sprint.startDate && (
                      <>
                        <span>start {new Date(sprint.startDate).toLocaleDateString()}</span>
                        <span>&middot;</span>
                      </>
                    )}

                    {sprint.endDate && (
                      <span>end {new Date(sprint.endDate).toLocaleDateString()}</span>
                    )}
                  </div>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-2" onclick="event.stopPropagation()">
                  {sprint.status === "planned" && (
                    <button
                      onclick={`openStartSprintDialog('${sprint._id}')`}
                      class="px-3 py-1.5 bg-surface-100 hover:bg-surface-200 dark:bg-ink-800 dark:hover:bg-ink-700 text-ink-900 dark:text-ink-100 text-sm font-medium rounded-lg transition-colors"
                    >
                      Start
                    </button>
                  )}

                  {sprint.status === "active" && (
                    <button
                      onclick={`openCompleteSprintDialog('${sprint._id}')`}
                      class="px-3 py-1.5 bg-peach-100 hover:bg-peach-200 dark:bg-peach-900/30 dark:hover:bg-peach-900/50 text-peach-700 dark:text-peach-300 text-sm font-medium rounded-lg transition-colors"
                    >
                      Complete
                    </button>
                  )}

                  <a
                    href={`/projects/${projectId}/sprints/${sprint._id}`}
                    class="px-3 py-1.5 border border-ink-200 dark:border-ink-700 hover:bg-surface-50 dark:hover:bg-ink-800 text-ink-600 dark:text-ink-300 text-sm font-medium rounded-lg transition-colors"
                  >
                    View
                  </a>

                  <button
                    onclick={`editSprint('${sprint._id}')`}
                    class="p-2 text-ink-400 hover:text-ink-600 dark:hover:text-ink-300 transition-colors"
                    title="Edit Sprint"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                  </button>

                  <button
                    onclick={`openDeleteSprintDialog('${sprint._id}')`}
                    class="p-2 text-ink-400 hover:text-red-600 dark:hover:text-red-400 transition-colors"
                    title="Delete Sprint"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="rounded-full bg-surface-100 dark:bg-ink-800 p-4 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-ink-900 dark:text-ink-100 mb-1">
            No sprints found
          </h3>
          <p class="text-ink-500 dark:text-ink-400 text-sm max-w-sm mb-4">
            There are no sprints yet for this project. Create your first sprint to start planning.
          </p>
          <Button onclick="document.getElementById('create_sprint_modal').showModal()">
            Create Your First Sprint
          </Button>
        </div>
      )}

      {sprints.length > 0 && (
        <div class="px-4 py-3 border-t border-ink-100 dark:border-ink-800 bg-surface-50 dark:bg-ink-900/50 flex items-center justify-between">
          <p class="text-xs text-ink-500 dark:text-ink-400">
            Showing <span class="font-medium">{sprints.length}</span> results
          </p>
        </div>
      )}
    </div>
  </div>

  <CreateSprintModal projectId={projectId!} unassignedIssues={unassignedIssues} />
  <EditSprintModal />
  <DeleteSprintDialog />
  <StartSprintDialog />
  <CompleteSprintDialog />
</AppLayout>

<script>
  /**
   * activateSprint is now handled by StartSprintDialog
   */
  
  // No longer needed here as StartSprintDialog handles it

  /**
   * deleteSprint is now handled by DeleteSprintDialog.
   */
</script>