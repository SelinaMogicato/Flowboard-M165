---
import AppLayout from "../../../../layouts/AppLayout.astro";
import Button from "../../../../components/ui/Button.astro";
import Input from "../../../../components/ui/Input.astro";
import Card from "../../../../components/ui/Card.astro";
import { ProjectMemberService } from "../../../../lib/services/project-member.service";
import { getSessionFromRequest } from "../../../../lib/auth/session";
import { ProjectService } from "../../../../lib/services/project.service";

const { projectId } = Astro.params;
const session = await getSessionFromRequest(Astro.cookies);

if (!session || !projectId) {
  return Astro.redirect("/login");
}

let members: any[] = [];
let project: any = null;
let error = null;

try {
  // Check if project exists and get basic info
  project = await ProjectService.getProjectById(
    projectId,
    session.user._id?.toString(),
  );
  if (!project) return Astro.redirect("/404");

  // Get members
  members = await ProjectMemberService.listMembers(
    projectId,
    session.user._id!.toString(),
  );
} catch (e: any) {
  console.error(e);
  if (e.message === "Unauthorized") return Astro.redirect("/403");
  error = e.message;
}

const currentUserMember = members.find(
  (m) => m.userId.toString() === session.user._id!.toString(),
);
const isOwner = currentUserMember?.role === "owner";
---

<AppLayout title={`Members - ${project?.name}`}>
  <div class="h-full min-h-0 flex flex-col max-w-5xl mx-auto w-full px-4 py-8">
    <div class="mb-8 border-b border-ink-200 dark:border-ink-700 pb-1">
      <div class="flex items-center justify-between mb-4">
        <h1
          class="text-3xl font-bold text-ink-900 dark:text-ink-50 flex items-center gap-4"
        >
          <div>
            {project?.name}
            <span class="text-ink-400 font-normal text-lg">/ Members</span>
          </div>
        </h1>
        <div class="flex items-center gap-2 mt-1">
          <a
            href={`/projects/${projectId}`}
            class="px-3 py-1 text-ink-500 dark:text-ink-400 hover:bg-surface-100 dark:hover:bg-ink-800 rounded-lg text-sm transition-colors"
          >
            Board
          </a>
          <div
            class="px-3 py-1 bg-peach-500 text-white rounded-lg text-sm font-medium"
          >
            Members
          </div>
        </div>
      </div>
    </div>

    {
      error && (
        <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-6 border border-red-200">
          {error}
        </div>
      )
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Members List -->
      <div class="lg:col-span-2 space-y-6">
        <Card class="bg-white dark:bg-ink-800">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-ink-900 dark:text-ink-100">
              Team Members
            </h2>
            <span
              class="text-sm text-ink-500 bg-ink-100 dark:bg-ink-900 px-2 py-1 rounded-md"
              >{members.length} members</span
            >
          </div>

          <ul class="divide-y divide-ink-100 dark:divide-ink-700">
            {
              members.map((member) => (
                <li class="py-4 flex items-center justify-between group">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-peach-100 dark:bg-peach-900/30 text-peach-600 dark:text-peach-400 flex items-center justify-center font-bold text-lg">
                      {member.user.name?.charAt(0).toUpperCase() ||
                        member.user.email.charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <h3 class="font-medium text-ink-900 dark:text-ink-100">
                        {member.user.name || "Unnamed User"}
                        {member.userId.toString() ===
                          session.user._id!.toString() && (
                          <span class="text-ink-400 text-sm font-normal ml-2">
                            (You)
                          </span>
                        )}
                      </h3>
                      <p class="text-sm text-ink-500 dark:text-ink-400">
                        {member.user.email}
                      </p>
                    </div>
                  </div>

                  <div class="flex items-center gap-4">
                    <span
                      class={`px-2.5 py-0.5 rounded-full text-xs font-medium border ${
                        member.role === "owner"
                          ? "bg-purple-100 text-purple-700 border-purple-200 dark:bg-purple-900/30 dark:text-purple-300 dark:border-purple-800"
                          : "bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800"
                      }`}
                    >
                      {member.role}
                    </span>

                    {isOwner && (
                      <button
                        class="p-2 text-ink-400 hover:text-red-600 dark:hover:text-red-400 transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
                        title="Remove Member"
                        onclick={`removeMember('${member.userId}')`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-5 w-5"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                          />
                        </svg>
                      </button>
                    )}
                  </div>
                </li>
              ))
            }
          </ul>
        </Card>
      </div>

      <!-- Invite / Add Member -->
      <div class="lg:col-span-1">
        {
          isOwner ? (
            <Card class="bg-white dark:bg-ink-800 sticky top-8">
              <h2 class="text-xl font-bold text-ink-900 dark:text-ink-100 mb-4">
                Add Member
              </h2>
              <p class="text-sm text-ink-500 dark:text-ink-400 mb-6">
                Add an existing user to this project by email. They must already
                have an account.
              </p>

              <form id="add-member-form" class="space-y-4">
                <Input
                  name="email"
                  type="email"
                  label="User Email"
                  placeholder="colleague@example.com"
                  required
                />

                <p id="add-message" class="text-sm font-medium hidden" />

                <Button type="submit" class="w-full">
                  Add to Project
                </Button>
              </form>
            </Card>
          ) : (
            <Card class="bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700">
              <div class="text-center py-6">
                <p class="text-ink-500 dark:text-ink-400 text-sm">
                  Only project owners can manage members.
                </p>
              </div>
            </Card>
          )
        }
      </div>
    </div>
  </div>
</AppLayout>

<script define:vars={{ projectId }}>
  // Add Member
  const addForm = document.getElementById("add-member-form");
  const addMessage = document.getElementById("add-message");

  addForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(addForm);
    const email = formData.get("email");
    const btn = addForm.querySelector('button[type="submit"]');

    addMessage.classList.add("hidden");
    addMessage.className = "text-sm font-medium hidden";

    const originalText = btn.innerText;
    btn.disabled = true;
    btn.innerText = "Adding...";

    try {
      const res = await fetch(`/api/projects/${projectId}/members`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const result = await res.json();

      addMessage.classList.remove("hidden");
      if (res.ok) {
        addMessage.textContent = "Member added successfully";
        addMessage.classList.add("text-green-600", "dark:text-green-400");
        addForm.reset();
        setTimeout(() => window.location.reload(), 1000);
      } else {
        addMessage.textContent = result.error || "Failed to add member";
        addMessage.classList.add("text-red-600", "dark:text-red-400");
      }
    } catch (err) {
      addMessage.classList.remove("hidden");
      addMessage.textContent = "An error occurred";
      addMessage.classList.add("text-red-600", "dark:text-red-400");
    } finally {
      btn.disabled = false;
      btn.innerText = originalText;
    }
  });

  // Remove Member
  window.removeMember = async (userId) => {
    if (!confirm("Are you sure you want to remove this member?")) return;

    try {
      const res = await fetch(`/api/projects/${projectId}/members`, {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ userId }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        alert(data.error || "Failed to remove member");
      }
    } catch (e) {
      alert("Error removing member");
    }
  };
</script>
