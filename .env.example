# Local Development
# MONGODB_URI=mongodb://root:examplepassword@localhost:27017/flowboard?authSource=admin
# MONGODB_DB=flowboard

# Docker Compose (Internal Network)
# MONGODB_URI=mongodb://root:examplepassword@mongo:27017/flowboard?authSource=admin
# MONGODB_DB=flowboard

# Production (Render / Atlas)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=flowboard

# Auth
SESSION_COOKIE_NAME=flowboard_session
SESSION_TTL_DAYS=14
PASSWORD_BCRYPT_ROUNDS=12
SESSION_SECRET=long_random_secret_string
MONGODB_URI=mongodb://root:examplepassword@localhost:27017/flowboard?authSource=admin
MONGODB_DB=flowboard
